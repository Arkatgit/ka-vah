data List a = Empty | Cons a (List a);

append : List a -> List a -> List a;
append = rec app. λxs. λys.
    match xs with
        Empty -> ys
        | Cons x rest -> Cons x (app rest ys)
    end;

max : Int -> Int -> Int;
max = λx. λy.
    if x <= y
    then y
    else x;

reverse : List a -> List a;
reverse = rec rev. λxs.
    match xs with
        Empty -> Empty
        | Cons x rest -> append (rev rest) (Cons x Empty)
    end;

take : Int -> List a -> List a;
take = rec t. λn. λxs.
    if n <= 0
    then Empty
    else match xs with
        Empty -> Empty
        | Cons x rest -> Cons x (t (n - 1) rest)
    end;

drop : Int -> List a -> List a;
drop = rec d. λn. λxs.
    if n <= 0
    then xs
    else match xs with
        Empty -> Empty
        | Cons x rest -> d (n - 1) rest
    end;

reversePrefix : Int -> List a -> List a;
reversePrefix = λn. λxs.
    append (reverse (take n xs)) (drop n xs);

head : List Int -> Int;
head = λxs.
    match xs with
        Empty -> 1
        | Cons x rest -> x
    end;

flipCount : List Int -> Int;
flipCount = rec count. λxs.
    if (head xs) = 1
    then 0
    else 1 + (count (reversePrefix (head xs) xs));

perm1 : List Int;
perm1 = Cons 1 (Cons 2 (Cons 3 (Cons 4 Empty)));

perm2 : List Int;
perm2 = Cons 2 (Cons 1 (Cons 3 (Cons 4 Empty)));

perm3 : List Int;
perm3 = Cons 3 (Cons 1 (Cons 2 (Cons 4 Empty)));

perm4 : List Int;
perm4 = Cons 4 (Cons 3 (Cons 2 (Cons 1 Empty)));

perms : List (List Int);
perms = Cons perm1 (Cons perm2 (Cons perm3 (Cons perm4 Empty)));

maxFlips : List (List Int) -> Int;
maxFlips = rec mf. λlists.
    match lists with
        Empty -> 0
        | Cons p rest -> max (flipCount p) (mf rest)
    end;

fannkuch : Int;
fannkuch = maxFlips perms;

main : Int;
main = fannkuch;